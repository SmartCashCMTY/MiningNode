diff --git a/lib/explorer.js b/lib/explorer.js
--- a/lib/explorer.js
+++ b/lib/explorer.js
@@ -595,6 +595,38 @@ module.exports = {
     });
   },
 
+  get_richlist_rpc_balances: function(items, cb) {
+    var candidates = Array.isArray(items) ? items.slice(0, 100) : [];
+    var result = [];
+
+    module.exports.syncLoop(candidates.length, function(loop) {
+      var i = loop.iteration();
+      var item = candidates[i];
+
+      if (!item || !item.a_id) {
+        loop.next();
+        return;
+      }
+
+      module.exports.get_address_balance(item.a_id, function(rpcBalance) {
+        if (rpcBalance && rpcBalance.balance > 0) {
+          result.push({
+            a_id: item.a_id,
+            balance: rpcBalance.balance,
+            received: rpcBalance.received,
+            name: item.name
+          });
+        }
+        loop.next();
+      });
+    }, function() {
+      result.sort(function(a, b) {
+        return b.balance - a.balance;
+      });
+      return cb(result.slice(0, 100));
+    });
+  },
+
