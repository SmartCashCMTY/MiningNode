+  get_smartnodes: function(cb) {
+    rpcCommand([{method:'smartnode', parameters: ['list', 'full']}], function(response) {
+      var smartnodes = [];
+
+      if (!response || response == 'There was an error. Check your console.') {
+        return cb(smartnodes);
+      }
+
+      Object.keys(response).forEach(function(outpoint) {
+        var fields = String(response[outpoint]).trim().split(/\s+/);
+        smartnodes.push({
+          outpoint: outpoint,
+          status: fields[0] || '',
+          protocol: fields[1] || '',
+          payee: fields[2] || '',
+          lastSeen: parseInt(fields[3]) || 0,
+          activeSeconds: parseInt(fields[4]) || 0,
+          lastPaidTime: parseInt(fields[5]) || 0,
+          lastPaidBlock: parseInt(fields[6]) || 0,
+          address: fields[7] || ''
+        });
+      });
+
+      smartnodes.sort(function(a, b) {
+        if (a.status == b.status) return a.address.localeCompare(b.address);
+        if (a.status == 'ENABLED') return -1;
+        if (b.status == 'ENABLED') return 1;
+        return a.status.localeCompare(b.status);
+      });
+
+      return cb(smartnodes);
+    });
+  },
+
