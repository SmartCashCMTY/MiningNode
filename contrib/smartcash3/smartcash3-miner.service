[Unit]
Description=SmartCash 3.0 recovery block producer
After=smartcash3.service
Requires=smartcash3.service

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/smartcash3/miner.env
RuntimeDirectory=smartcash3
RuntimeDirectoryMode=0755
ExecStart=/usr/local/sbin/smartcash3-mine-once
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
TimeoutStartSec=10min
