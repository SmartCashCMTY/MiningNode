--- old/evutil_rand.c
+++ new/evutil_rand.c
@@ -174,6 +174,12 @@
 void
 evutil_secure_rng_add_bytes(const char *buf, size_t n)
 {
+#if defined(__linux__) && defined(_EVENT_HAVE_ARC4RANDOM)
+	(void)buf;
+	(void)n;
+	return;
+#else
 	arc4random_addrandom((unsigned char*)buf,
 	    n>(size_t)INT_MAX ? INT_MAX : (int)n);
+#endif
 }
